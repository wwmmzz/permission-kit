{
  "name": "@eycraf/permission-kit-vite-plugin",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:types": "vitest run src/options.types.test.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@babel/parser": "latest",
    "@babel/traverse": "latest",
    "@babel/types": "latest",
    "fast-glob": "^3.3.3",
    "magic-string": "latest",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "devDependencies": {
    "@types/babel__traverse": "latest",
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
